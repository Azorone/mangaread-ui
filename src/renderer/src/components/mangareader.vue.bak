/* ==================== 灯箱（全屏预览）样式 ==================== */
/* 灯箱遮罩/背景层 */
.lightbox-overlay {
  /* 固定定位，覆盖整个视口 */
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
