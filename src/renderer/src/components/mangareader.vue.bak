  display: flex;
  justify-content: center;
  align-items: center;
  /* 确保在最顶层 */
  z-index: 999;
}

/* 灯箱内容容器 */
.lightbox-content {
  /* 相对定位，用于页码定位 */
  position: relative;
  /* 限制最大尺寸 */
  max-width: 80%;
  max-height: 85%;
  /* 垂直排列：图片 + 页码 */
  display: flex;
  flex-direction: column;
  /* 内容居中 */
  align-items: center;
}

/* 灯箱中的大图 */
.lightbox-content img {
  /* 响应式宽度 */
  max-width: 100%;
  /* 最大高度（视口80%） */
  max-height: 80vh;
  /* 边框 */
  border: 1px solid #444;
  /* 圆角 */
  border-radius: 4px;
  /* 阴影效果 */
  box-shadow: 0 0 20px rgba(0,0,0,0.5);
}

/* 页码计数器 */
.lightbox-counter {
  /* 与图片的间距 */
  margin-top: 10px;
  /* 灰色文字 */
  color: #aaa;
  /* 小字体 */
  font-size: 14px;
