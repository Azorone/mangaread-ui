<script setup>
// ========================
// 导入必要的Vue和第三方库
// ========================
import { ref, onMounted, onBeforeUnmount, watch } from 'vue';
// Cropper: 专业的图片裁剪库，支持旋转、缩放、移动等操作
import Cropper from 'cropperjs';
import 'cropperjs/dist/cropper.css';

// ========================
// 响应式数据声明
// ========================
// 当前显示的漫画图片URL
const currentMangaPage = ref('https://picsum.photos/1200/1800'); 
// 图片DOM元素引用，用于初始化Cropper实例
const imageRef = ref(null);
// Cropper实例，管理图片的所有编辑操作
const cropper = ref(null);
// 裁剪模式开关标志
const isCropping = ref(false);
// 存储所有裁剪后的Base64图片数据
const croppedList = ref([]);

// ========================
// 灯箱（全屏预览）相关状态
// ========================
// 控制是否显示全屏灯箱预览
const showLightbox = ref(false);
// 灯箱中当前预览的图片在croppedList中的索引
const activePreviewIndex = ref(0);

// ========================
// 分页相关状态
// ========================
// 当前页码（从1开始）
const currentPage = ref(1);
// 漫画总页数
const totalPages = ref(100);

// ========================
// 侧边栏相关状态
// ========================
// 控制是否显示目录面板
const showContents = ref(false);
// 控制是否显示漫画列表面板
const showMangaList = ref(false);
// 控制是否显示阅读历史面板
const showHistory = ref(false);

// ========================
// 漫画列表数据
// ========================
// 漫画列表数据
const mangaList = ref([
  { id: 1, title: '漫画1', chapters: 120 },
  { id: 2, title: '漫画2', chapters: 85 },
  { id: 3, title: '漫画3', chapters: 200 },
  { id: 4, title: '漫画4', chapters: 45 },
  { id: 5, title: '漫画5', chapters: 150 }
]);

// ========================
// 目录数据（当前漫画的章节列表）
// ========================
// 目录列表
const contentsList = ref([
  '第1卷 - 开始',
  '第2卷 - 冒险',
  '第3卷 - 转折',
  '第4卷 - 高潮',
  '第5卷 - 结局'
]);

// ========================
// 阅读历史数据
// ========================
// 阅读历史列表（记录用户浏览过的漫画和页码）
const historyList = ref([
  { id: 1, manga: '漫画1', page: 45, chapter: '第5卷', time: '2小时前' },
  { id: 2, manga: '漫画2', page: 120, chapter: '第3卷', time: '1天前' },
  { id: 3, manga: '漫画3', page: 78, chapter: '第2卷', time: '3天前' },
  { id: 4, manga: '漫画1', page: 30, chapter: '第3卷', time: '1周前' },
  { id: 5, manga: '漫画4', page: 15, chapter: '第1卷', time: '2周前' }
]);

// ========================
// 图片缓存容器相关
// ========================
// 图片缓存队列 - 存储预取的图片二进制数据（Base64格式）
const imageCacheQueue = ref([]);
// 预取数量设置（默认预取5张）
const prefetchCountSetting = ref(5);
// 最大缓存数量设置（默认最多缓存20张）
const maxCacheSizeSetting = ref(20);
// 设置面板显示控制
const showCacheSettings = ref(false);
// 正在预取的标志
const isPrefetching = ref(false);
// 缓存容器当前占用的内存大小（字节）
const cacheSizeInBytes = ref(0);

// ========================
// 漫画图片列表相关
// ========================
// 漫画图片列表（从服务器获取的JSON数据）
const mangaImageList = ref([]);
// 当前漫画ID
const currentMangaId = ref(1);
// 已加载的页码缓存（用于快速查询）
const pageUrlMap = new Map(); // { pageNum: { url, ...otherData } }

// ========================
// Cropper图片编辑器初始化
// ========================
const initCropper = () => {
  // 确保图片DOM节点已存在
  if (!imageRef.value) return;
  
  // 初始化Cropper实例，配置裁剪参数
  cropper.value = new Cropper(imageRef.value, {
    viewMode: 0,        // 0: 自由放大/缩小，图片能充分利用容器空间
    autoCrop: false,     // 禁用自动裁剪，需手动启用
    movable: true,       // 支持移动图片
    zoomable: true,      // 支持缩放图片
    scalable: false,     // 禁用缩放选区
    rotatable: true,     // 支持旋转图片
    background: false,   // 禁用背景
    ready() {
      // Cropper初始化完成时的回调
      console.log('漫画图片加载完成，裁剪器就绪');
      // 自动适配屏幕大小
      fitToScreen();
    }
  });
};

// ========================
// 自适应屏幕尺寸
// ========================
const fitToScreen = () => {
  // 确保Cropper实例存在
  if (!cropper.value) return;
  
  try {
    // 获取容器（视口）尺寸
    const containerData = cropper.value.getContainerData();
    // 获取原始图片尺寸
    const imageData = cropper.value.getImageData();

    // 基础检查：确保获取到了数据
    if (!containerData || !imageData) {
      console.warn('容器或图片数据未就绪，跳过自适应操作');
      return;
    }

    // 如果容器尺寸异常小，尝试等待后重试
    if (containerData.width < 50 || containerData.height < 50) {
      console.warn('容器尺寸过小，延迟重试自适应');
      setTimeout(fitToScreen, 200);
      return;
    }

    // 计算缩放比例（取宽高较小值，确保图片完全显示）
    const ratio = Math.min(
      containerData.width / imageData.naturalWidth,
      containerData.height / imageData.naturalHeight
    );

    // 缩放到计算的比例
    cropper.value.zoomTo(ratio);
    // 将图片居中显示
    cropper.value.moveTo(
      (containerData.width - imageData.naturalWidth * ratio) / 2,
      (containerData.height - imageData.naturalHeight * ratio) / 2
    );
  } catch (error) {
    // 捕获任何错误，防止应用崩溃
    console.warn('自适应屏幕时出错：', error);
  }
};

// ========================
// 右键点击事件 - 确认裁剪
// ========================
const handleRightClick = (e) => {
  // 仅在裁剪模式启用且Cropper存在时响应
  if (!isCropping.value || !cropper.value) return;

  // 获取当前选区数据
  const cropData = cropper.value.getData();
  // 检查选区是否有意义（宽高都>10px）
  if (cropData.width > 10 && cropData.height > 10) {
    // 保存裁剪后的图片到列表
    getCroppedImage();
    // 清除选区框
    cropper.value.clear();
    console.log('右键确认：裁剪成功并已存入列表');
  }
};

// ========================
// 切换裁剪模式
// ========================
const toggleCrop = () => {
  // 确保Cropper实例存在
  if (!cropper.value) return;
  // 切换裁剪模式状态
  isCropping.value = !isCropping.value;
  
  if (isCropping.value) {
    // 启用裁剪模式，显示选区框
    cropper.value.crop();
  } else {
    // 禁用裁剪模式，清除选区框
    cropper.value.clear();
  }
};

// ========================
// 图片缩放和旋转
// ========================
// 缩放图片 (value正值放大，负值缩小)
const zoom = (value) => cropper.value?.zoom(value);
// 旋转图片 (度数，正值顺时针)
const rotate = (deg) => cropper.value?.rotate(deg);

// ========================
// 获取裁剪后的图片
// ========================
const getCroppedImage = () => {
  // 确保Cropper实例存在
  if (!cropper.value) return;
  
  try {
    // 获取裁剪后的Canvas画布对象
    // maxWidth/maxHeight: 限制导出图片的最大尺寸
    const canvas = cropper.value.getCroppedCanvas({
      maxWidth: 2048,
      maxHeight: 2048,
    });
    
    // 检查canvas是否有效
    if (!canvas) {
      console.error('Canvas获取失败');
      return;
    }
    
    // 将Canvas转换为Base64编码的PNG图片
    const base64 = canvas.toDataURL('image/png');
    
    // 检查base64是否有效（应该以data:image开头）
    if (!base64 || !base64.startsWith('data:image')) {
      console.error('Base64图片数据无效');
      return;
    }
    
    // 将新裁剪的图片添加到列表开头（最新的在前）
    croppedList.value.unshift(base64);
    console.log('图片已保存，当前列表数:', croppedList.value.length);
  } catch (error) {
    console.error('裁剪图片时出错：', error);
  }
};

// ========================
// 灯箱（全屏预览）控制方法
// ========================

// 打开灯箱，显示指定索引的图片
const openLightbox = (index) => {
  // 设置要预览的图片索引
  activePreviewIndex.value = index;
  // 显示灯箱层
  showLightbox.value = true;
};

// 关闭灯箱
const closeLightbox = () => {
  showLightbox.value = false;
};

// 预览上一张图片（带循环）
const prevPreview = () => {
  if (activePreviewIndex.value > 0) {
    // 不是第一张，向前翻
    activePreviewIndex.value--;
  } else {
    // 已经是第一张，循环到最后一张
    activePreviewIndex.value = croppedList.value.length - 1;
  }
};

// 预览下一张图片（带循环）
const nextPreview = () => {
  if (activePreviewIndex.value < croppedList.value.length - 1) {
    // 不是最后一张，向后翻
    activePreviewIndex.value++;
  } else {
    // 已经是最后一张，循环到第一张
    activePreviewIndex.value = 0;
  }
};

// ========================
// 键盘快捷键处理
// ========================
// 仅在灯箱打开时响应（Electron应用推荐使用此方式）
// ========================
// 键盘快捷键处理（全局）
// ========================
const handleKeyDown = (e) => {
  // 灯箱打开时的快捷键
  if (showLightbox.value) {
    // 左箭头: 上一张
    if (e.key === 'ArrowLeft') {
      e.preventDefault();
      prevPreview();
    } 
    // 右箭头: 下一张
    else if (e.key === 'ArrowRight') {
      e.preventDefault();
      nextPreview();
    } 
    // Esc: 关闭灯箱
    else if (e.key === 'Escape') {
      closeLightbox();
    }
    return;
  }

  // 灯箱未打开时的快捷键
  // 左箭头: 前一页（换页）
  if (e.key === 'ArrowLeft') {
    e.preventDefault();
    prevPage();
  } 
  // 右箭头: 后一页（换页）
  else if (e.key === 'ArrowRight') {
    e.preventDefault();
    nextPage();
  }
  // 加号键（=）: 放大图片
  else if (e.key === '+' || e.key === '=') {
    e.preventDefault();
    zoom(0.1);
  }
  // 减号键（-）: 缩小图片
  else if (e.key === '-' || e.key === '_') {
    e.preventDefault();
    zoom(-0.1);
  }
};

// ========================
// 前一页/后一页功能 - 与缓存容器结合
// ========================
// 前一页按钮（进入上一页漫画）
const prevPage = () => {
  if (currentPage.value > 1) {
    currentPage.value--;
    console.log(`翻到第 ${currentPage.value} 页`);
    // 从缓存获取前一页的图片
    loadPageFromCache();
  }
};

// 后一页按钮（进入下一页漫画）
const nextPage = () => {
  if (currentPage.value < totalPages.value) {
    currentPage.value++;
    console.log(`翻到第 ${currentPage.value} 页`);
    // 从缓存获取下一页的图片
    loadPageFromCache();
  }
};

// 从缓存容器中加载页面图片
const loadPageFromCache = async () => {
  // 首先尝试从缓存获取图片
  let imageData = getImageFromCache(currentPage.value);
  
  // 如果缓存为空，等待预取完成再获取
  if (!imageData && imageCacheQueue.value.length === 0) {
    console.log('缓存为空，进行预取...');
    // 等待预取完成
    await prefetchImagesToCache();
    // 预取完成后获取图片
    imageData = getImageFromCache(currentPage.value);
  }
  
  // 加载图片到主显示区
  if (imageData) {
    currentMangaPage.value = imageData;
    console.log(`页面 ${currentPage.value} 加载成功，来自缓存容器`);
  } else {
    console.warn(`页面 ${currentPage.value} 缓存获取失败`);
  }
};

// ========================
// 侧边栏控制方法
// ========================
// 切换目录面板显示/隐藏
const toggleContents = () => {
  showContents.value = !showContents.value;
  // 打开目录时关闭漫画列表
  if (showContents.value) {
    showMangaList.value = false;
  }
};

// 切换漫画列表面板显示/隐藏
const toggleMangaList = () => {
  showMangaList.value = !showMangaList.value;
  // 打开漫画列表时关闭目录
  if (showMangaList.value) {
    showContents.value = false;
  }
};

// 选择目录项（跳转到指定章节）
const selectContent = (index) => {
  console.log(`选中目录: ${contentsList.value[index]}`);
  // 根据选中的目录跳转到对应的页面
  // 假设每个章节的起始页 = (index + 1) * 20
  currentPage.value = (index + 1) * 20;
  // 从缓存加载该页漫画图片
  loadPageFromCache();
  showContents.value = false;
};

// 选择漫画（切换漫画）
const selectManga = (mangaId) => {
  const manga = mangaList.value.find(m => m.id === mangaId);
  console.log(`选中漫画: ${manga.title}`);
  // 切换漫画，重置到第1页
  currentPage.value = 1;
  // 从缓存加载漫画的第一页
  loadPageFromCache();
  showMangaList.value = false;
};

// ========================
// 阅读历史控制方法
// ========================
// 切换阅读历史面板显示/隐藏
const toggleHistory = () => {
  showHistory.value = !showHistory.value;
  // 打开历史时关闭其他侧边栏
  if (showHistory.value) {
    showContents.value = false;
    showMangaList.value = false;
  }
};

// 选择历史记录项（跳转到指定的漫画和页码）
const selectHistory = (historyItem) => {
  console.log(`继续阅读: ${historyItem.manga} - 第${historyItem.page}页`);
  // 跳转到指定的漫画和页码
  currentPage.value = historyItem.page;
  // 从缓存加载对应页数的漫画图片
  loadPageFromCache();
  showHistory.value = false;
};

// 清空阅读历史
const clearHistory = () => {
  if (confirm('确认要清空所有阅读历史吗？')) {
    historyList.value = [];
    console.log('阅读历史已清空');
  }
};

// ========================
// 图片缓存管理方法
// ========================

// 从服务器获取漫画图片列表（模拟JSON数据）
const fetchMangaImageList = async (mangaId) => {
  return new Promise((resolve) => {
    // 模拟服务器延迟
    setTimeout(() => {
      // 模拟漫画图片列表JSON数据
      // 生成100页的漫画图片列表
      const imageList = [];
      for (let page = 1; page <= 100; page++) {
        imageList.push({
          id: page,
          page: page,
          chapter: Math.ceil(page / 20), // 每20页为一章
          url: `https://picsum.photos/1200/1800?id=${mangaId}_${page}`, // 使用演示URL
          title: `第${page}页`,
          size: 0, // 初始化时为0，实际获取后更新
          timestamp: Date.now() - (100 - page) * 1000 // 模拟递减时间戳
        });
      }
      console.log(`成功获取漫画 ${mangaId} 的图片列表，共 ${imageList.length} 张`);
      mangaImageList.value = imageList;
      
      // 构建页码映射表以加快查询
      imageList.forEach(img => {
        pageUrlMap.set(img.page, img);
      });
      
      resolve(imageList);
    }, 200); // 模拟网络延迟
  });
};

// 根据页码获取图片URL
const getImageUrlByPage = (pageNum) => {
  // 先从映射表查询
  if (pageUrlMap.has(pageNum)) {
    return pageUrlMap.get(pageNum);
  }
  
  // 再从列表中查询
  const imageData = mangaImageList.value.find(img => img.page === pageNum);
  if (imageData) {
    pageUrlMap.set(pageNum, imageData);
    return imageData;
  }
  
  console.warn(`页码 ${pageNum} 未找到对应的图片数据`);
  return null;
};

// 根据页码列表获取多张图片的URL数据
const getImageUrlsByPages = (pageNumbers) => {
  return pageNumbers
    .map(page => getImageUrlByPage(page))
    .filter(item => item !== null);
};

// 从URL获取图片二进制数据并转换为Base64
const fetchImageFromServer = async (imageData) => {
  // imageData 包含 { url, page, ... } 等信息
  return new Promise(async (resolve) => {
    try {
      if (!imageData || !imageData.url) {
        throw new Error('图片数据无效');
      }
      
      // 从URL获取图片二进制数据
      const response = await fetch(imageData.url);
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      
      // 转换为Blob
      const blob = await response.blob();
      
      // 转换为Base64
      const reader = new FileReader();
      reader.onload = (e) => {
        const base64Data = e.target.result;
        resolve({
          data: base64Data, // Base64格式的图片数据
          size: blob.size,  // 图片大小（字节）
          timestamp: Date.now()
        });
      };
      reader.onerror = () => {
        throw new Error('Failed to read blob as data URL');
      };
      reader.readAsDataURL(blob);
    } catch (error) {
      console.error('获取图片时出错：', error);
      resolve(null);
    }
  });
};

// 预取图片到缓存容器（根据页码预取）
const prefetchImagesToCache = async () => {
  if (isPrefetching.value) return;
  if (mangaImageList.value.length === 0) return; // 还没有加载图片列表
  
  isPrefetching.value = true;

  try {
    // 计算需要预取的页码范围
    // 从当前页开始，预取 prefetchCountSetting 张
    const startPage = currentPage.value;
    const endPage = Math.min(
      currentPage.value + prefetchCountSetting.value - 1,
      totalPages.value
    );
    
    // 获取需要预取的页码列表
    const pagesToPrefetch = [];
    for (let page = startPage; page <= endPage; page++) {
      // 检查这一页是否已经在缓存队列中
      const isInCache = imageCacheQueue.value.some(item => item.page === page);
      if (!isInCache) {
        pagesToPrefetch.push(page);
      }
    }
    
    if (pagesToPrefetch.length > 0) {
      // 获取这些页面的图片URL数据
      const imageDataList = getImageUrlsByPages(pagesToPrefetch);
      
      // 并发获取这些页面的图片二进制数据
      const promises = imageDataList.map(imgData => 
        fetchImageFromServer(imgData)
      );
      
      const fetchedImages = await Promise.all(promises);
      
      // 将成功获取的图片添加到缓存队列
      fetchedImages.forEach((imageData, index) => {
        if (imageData) {
          const page = pagesToPrefetch[index];
          imageCacheQueue.value.push({
            page: page,
            data: imageData.data,
            size: imageData.size,
            timestamp: imageData.timestamp
          });
          // 累计缓存大小
          cacheSizeInBytes.value += imageData.size;
        }
      });
      
      const successCount = fetchedImages.filter(d => d !== null).length;
      if (successCount > 0) {
        const pageRange = pagesToPrefetch.length === 1 
          ? `第${pagesToPrefetch[0]}页` 
          : `第${pagesToPrefetch[0]}-${pagesToPrefetch[pagesToPrefetch.length - 1]}页`;
        console.log(`预取了 ${successCount} 张图片（${pageRange}），当前缓存: ${imageCacheQueue.value.length} 张，内存占用: ${(cacheSizeInBytes.value / 1024 / 1024).toFixed(2)} MB`);
      }
    }
    
    // 检查缓存是否超过最大数量，清理最老的
    while (imageCacheQueue.value.length > maxCacheSizeSetting.value) {
      const removed = imageCacheQueue.value.shift();
      if (removed) {
        cacheSizeInBytes.value -= removed.size;
      }
      console.log('缓存超过最大数量，清理最老的图片');
    }
  } catch (error) {
    console.error('预取图片时出错：', error);
  } finally {
    isPrefetching.value = false;
  }
};

// 从缓存中获取图片二进制数据（Base64格式）
const getImageFromCache = (pageNum = null) => {
  let cachedImage = null;
  let index = -1;
  if (pageNum !== null) {
    index = imageCacheQueue.value.findIndex(item => item.page === pageNum);
    if (index !== -1) {
      cachedImage = imageCacheQueue.value[index];
    }
  } else {
    if (imageCacheQueue.value.length > 0) {
      cachedImage = imageCacheQueue.value[0];
      index = 0;
    }
  }
  if (cachedImage) {
    imageCacheQueue.value.splice(index, 1);
    cacheSizeInBytes.value -= cachedImage.size;
    prefetchImagesToCache();
    return cachedImage.data;
  }
  return null;
};

// 保存缓存设置
const saveCacheSettings = () => {
  // 限制设置范围
  prefetchCountSetting.value = Math.max(1, Math.min(20, prefetchCountSetting.value));
  maxCacheSizeSetting.value = Math.max(
    prefetchCountSetting.value,
    Math.min(100, maxCacheSizeSetting.value)
  );
  
  // 关闭设置面板
  showCacheSettings.value = false;
  
  // 立即预取补充缓存
  console.log(`缓存设置已保存 - 预取数: ${prefetchCountSetting.value}, 最大容量: ${maxCacheSizeSetting.value}`);
  prefetchImagesToCache();
};

// ========================
// Vue生命周期钩子
// ========================

// 组件挂载时：初始化编辑器和事件监听
onMounted(async () => {
  // 初始化Cropper编辑器
  initCropper();
  // 延迟调用fitToScreen，确保DOM完全渲染且Cropper完全初始化
  setTimeout(() => {
    fitToScreen();
  }, 100);
  // 监听视口大小变化，自动重新适配
  window.addEventListener('resize', fitToScreen);
  // 监听键盘事件（用于灯箱导航）
  window.addEventListener('keydown', handleKeyDown);
  
  // 初始化时先获取漫画图片列表，然后预取和加载第一页
  try {
    await fetchMangaImageList(currentMangaId.value);
    await prefetchImagesToCache();
    loadPageFromCache();
  } catch (error) {
    console.error('初始化缓存时出错：', error);
  }
  
  // 定期补充缓存（每3秒检查一次是否需要补充）
  const prefetchInterval = setInterval(() => {
    prefetchImagesToCache();
  }, 3000);
  
  // 保存interval ID以便在卸载时清理
  window._prefetchIntervalId = prefetchInterval;
});

// 组件卸载前：清理资源和事件监听
onBeforeUnmount(() => {
  // 销毁Cropper实例，释放内存
  cropper.value?.destroy();
  // 移除事件监听器
  window.removeEventListener('resize', fitToScreen);
  window.removeEventListener('keydown', handleKeyDown);
  
  // 清理预取的定时器
  if (window._prefetchIntervalId) {
    clearInterval(window._prefetchIntervalId);
    delete window._prefetchIntervalId;
  }
});

// ========================
// 数据监听 - 当漫画页面URL改变时
// ========================
watch(currentMangaPage, (newUrl) => {
  if (cropper.value) {
    // 替换Cropper中的图片为新URL
    cropper.value.replace(newUrl);
  }
});

</script>

<template>
  <!-- 漫画阅读器主容器 -->
  <div class="manga-app">
    <!-- ==================== 工具栏区域 ==================== -->
    <div class="toolbar">
      <!-- 左侧：导航和控制按钮 -->
      <div class="group">
        <!-- 漫画列表按钮 -->
        <button @click="toggleMangaList" title="打开漫画列表">
          📚 漫画列表
        </button>
        <!-- 目录按钮 -->
        <button @click="toggleContents" title="打开目录">
          📖 目录
        </button>
        <!-- 阅读历史按钮 -->
        <button @click="toggleHistory" title="打开阅读历史">
          ⏱️ 历史记录
        </button>
        <!-- 缓存设置按钮 -->
        <button @click="showCacheSettings = true" title="设置图片缓存">
          ⚙️ 缓存设置
        </button>
      </div>

      <!-- 中心：图片编辑工具组 -->
      <div class="group">
        <!-- 放大按钮 -->
        <button @click="zoom(0.1)" title="放大 (键盘: + 键)">➕ 放大</button>
        <!-- 缩小按钮 -->
        <button @click="zoom(-0.1)" title="缩小 (键盘: - 键)">➖ 缩小</button>
        <!-- 左旋转 -->
        <button @click="rotate(-90)">↺ 左旋</button>
        <!-- 右旋转 -->
        <button @click="rotate(90)">↻ 右旋</button>
        <!-- 自适应屏幕 -->
        <button @click="fitToScreen">📺 自适应屏幕</button>
      </div>

      <!-- 右侧：裁剪和分页工具 -->
      <div class="group">
        <!-- 切换裁剪模式 -->
        <button :class="{ active: isCropping }" @click="toggleCrop">
          {{ isCropping ? '禁用裁剪' : '✂️ 自由裁剪' }}
        </button>
        <!-- 保存选区（仅在裁剪模式启用时可用） -->
        <button :disabled="!isCropping" @click="getCroppedImage">💾 保存选区</button>
        <!-- 分页按钮 -->
        <button @click="prevPage" :disabled="currentPage === 1" title="前一页 (键盘: ← 左箭头)">
          ⬅️ 前一页
        </button>
        <!-- 页码显示 -->
        <span class="page-indicator">{{ currentPage }} / {{ totalPages }}</span>
        <!-- 下一页按钮 -->
        <button @click="nextPage" :disabled="currentPage === totalPages" title="下一页 (键盘: → 右箭头)">
          下一页 ➡️
        </button>
      </div>
    </div>

    <!-- ==================== 主图片查看区域 ==================== -->
    <!-- @contextmenu.prevent: 禁用默认右键菜单，自定义右键行为 -->
    <div class="viewer-container" @contextmenu.prevent="handleRightClick">
      <!-- 图片包装层 -->
      <div class="img-wrapper">
        <!-- 漫画当前页图片（ref绑定用于Cropper初始化） -->
        <img ref="imageRef" :src="currentMangaPage" alt="Manga Page" />
      </div>
    </div>

    <!-- ==================== 预览条区域 ==================== -->
    <!-- v-if: 仅当有裁剪图片时显示 -->
    <div v-if="croppedList.length > 0" class="preview-bar">
      <!-- 预览信息文本 -->
      <span>裁剪预览({{ croppedList.length }}) - 点击图片可放大：</span>
      <!-- 预览图片列表 -->
      <div class="preview-list">
        <!-- 循环渲染所有裁剪的图片缩略图，点击打开灯箱 -->
        <img 
          v-for="(item, index) in croppedList" 
          :key="index" 
          :src="item" 
          alt="Preview" 
          @click="openLightbox(index)"
        />
      </div>
    </div>

    <!-- ==================== 目录侧边栏 ==================== -->
    <!-- 目录面板（从左侧滑出） -->
    <div v-if="showContents" class="sidebar contents-sidebar">
      <!-- 目录头部 -->
      <div class="sidebar-header">
        <h3>📖 目录</h3>
        <button class="close-sidebar-btn" @click="toggleContents">✕</button>
      </div>
      <!-- 目录内容列表 -->
      <div class="sidebar-content">
        <ul class="contents-list">
          <li 
            v-for="(content, index) in contentsList" 
            :key="index"
            class="contents-item"
            @click="selectContent(index)"
          >
            {{ content }}
          </li>
        </ul>
      </div>
    </div>

    <!-- ==================== 漫画列表侧边栏 ==================== -->
    <!-- 漫画列表面板（从左侧滑出） -->
    <div v-if="showMangaList" class="sidebar manga-list-sidebar">
      <!-- 漫画列表头部 -->
      <div class="sidebar-header">
        <h3>📚 漫画列表</h3>
        <button class="close-sidebar-btn" @click="toggleMangaList">✕</button>
      </div>
      <!-- 漫画列表内容 -->
      <div class="sidebar-content">
        <ul class="manga-list">
          <li 
            v-for="manga in mangaList" 
            :key="manga.id"
            class="manga-item"
            @click="selectManga(manga.id)"
          >
            <div class="manga-title">{{ manga.title }}</div>
            <div class="manga-chapters">{{ manga.chapters }} 话</div>
          </li>
        </ul>
      </div>
    </div>

    <!-- ==================== 阅读历史侧边栏 ==================== -->
    <!-- 历史记录面板（从左侧滑出） -->
    <div v-if="showHistory" class="sidebar history-sidebar">
      <!-- 历史记录头部 -->
      <div class="sidebar-header">
        <h3>⏱️ 阅读历史</h3>
        <button class="close-sidebar-btn" @click="toggleHistory">✕</button>
      </div>
      <!-- 历史记录内容 -->
      <div class="sidebar-content">
        <div v-if="historyList.length > 0" class="history-list">
          <div 
            v-for="item in historyList" 
            :key="item.id"
            class="history-item"
            @click="selectHistory(item)"
          >
            <div class="history-title">{{ item.manga }}</div>
            <div class="history-meta">{{ item.chapter }} - 第{{ item.page }}页</div>
            <div class="history-time">{{ item.time }}</div>
          </div>
        </div>
        <div v-else class="empty-message">暂无阅读历史</div>
      </div>
      <!-- 清空历史按钮 -->
      <div v-if="historyList.length > 0" class="sidebar-footer">
        <button class="clear-btn" @click="clearHistory">🗑️ 清空历史</button>
      </div>
    </div>

    <!-- ==================== 灯箱遮罩（防止点击侧边栏外）==================== -->
    <!-- 当侧边栏打开时，点击遮罩关闭侧边栏 -->
    <div 
      v-if="showContents || showMangaList || showHistory" 
      class="sidebar-overlay"
      @click="showContents = false; showMangaList = false; showHistory = false"
    ></div>

    <!-- ==================== 图片缓存设置面板 ==================== -->
    <!-- 缓存设置弹窗（模态对话框） -->
    <div v-if="showCacheSettings" class="cache-settings-modal">
      <!-- 背景遮罩 -->
      <div class="cache-settings-overlay" @click="showCacheSettings = false"></div>
      
      <!-- 设置面板内容 -->
      <div class="cache-settings-panel">
        <div class="cache-settings-header">
          <h3>⚙️ 图片缓存设置</h3>
          <button class="close-btn" @click="showCacheSettings = false" title="关闭">✕</button>
        </div>
        
        <div class="cache-settings-body">
          <!-- 预取数量设置 -->
          <div class="setting-item">
            <label for="prefetches">预取图片数量：</label>
            <input 
              id="prefetches"
              type="number" 
              v-model.number="prefetchCountSetting" 
              min="1" 
              max="20"
              class="setting-input"
            />
            <span class="setting-hint">（1-20张）</span>
          </div>
          
          <!-- 最大缓存数设置 -->
          <div class="setting-item">
            <label for="maxcache">最大缓存数量：</label>
            <input 
              id="maxcache"
              type="number" 
              v-model.number="maxCacheSizeSetting" 
              :min="prefetchCountSetting"
              max="100"
              class="setting-input"
            />
            <span class="setting-hint">（{{ prefetchCountSetting }}-100张）</span>
          </div>
          
          <!-- 缓存统计信息 -->
          <div class="cache-status">
            <p>缓存图片数：<strong>{{ imageCacheQueue.length }} / {{ maxCacheSizeSetting }}</strong> 张</p>
            <p>内存占用：<strong>{{ (cacheSizeInBytes / 1024 / 1024).toFixed(2) }}</strong> MB</p>
            <div class="cache-progress">
              <div class="progress-bar" :style="{ width: (imageCacheQueue.length / maxCacheSizeSetting * 100) + '%' }"></div>
            </div>
          </div>
        </div>
        
        <div class="cache-settings-footer">
          <button class="btn-primary" @click="saveCacheSettings">保存设置</button>
          <button class="btn-secondary" @click="showCacheSettings = false">取消</button>
        </div>
      </div>
    </div>

    <!-- ==================== 灯箱（全屏预览）区域 ==================== -->
    <!-- v-if: 仅当灯箱打开时显示 -->
    <!-- @click.self: 点击黑色背景关闭灯箱（不会误触内容） -->
    <div v-if="showLightbox" class="lightbox-overlay" @click.self="closeLightbox">
      <!-- 关闭按钮 -->
      <button class="close-btn" @click="closeLightbox">✕</button>
      
      <!-- 上一张按钮 -->
      <button class="nav-btn prev-btn" @click="prevPreview">❮</button>
      
      <!-- 灯箱内容（大图 + 页码） -->
      <div class="lightbox-content">
        <!-- 当前预览的大图 -->
        <img :src="croppedList[activePreviewIndex]" alt="Enlarged Preview" />
        <!-- 页码计数器 -->
        <div class="lightbox-counter">
          {{ activePreviewIndex + 1 }} / {{ croppedList.length }}
        </div>
      </div>
      
      <!-- 下一张按钮 -->
      <button class="nav-btn next-btn" @click="nextPreview">❯</button>
    </div>
  </div>
</template>

