  /* 居中图标 */
  display: flex;
  justify-content: center;
  align-items: center;
  /* 背景色平滑过渡 */
  transition: background 0.2s;
}

/* 按钮悬停效果 */
.close-btn:hover, .nav-btn:hover {
  /* 更不透明的白色背景 */
  background: rgba(255, 255, 255, 0.3);
}

/* ==================== 关闭按钮位置和大小 ==================== */
.close-btn {
  /* 右上角位置 */
  top: 30px;
  right: 30px;
