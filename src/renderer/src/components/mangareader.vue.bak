  width: 40px;
  height: 40px;
  /* 图标大小 */
  font-size: 20px;
}

/* ==================== 导航按钮（上/下箭头）位置和大小 ==================== */
.nav-btn {
  /* 垂直居中 */
  top: 50%;
  transform: translateY(-50%);
  /* 圆形尺寸 */
  width: 50px;
  height: 50px;
  /* 图标大小 */
  font-size: 24px;
}

/* 上一张按钮位置（左侧） */
.prev-btn {
  left: 30px;
}

/* 下一张按钮位置（右侧） */
.next-btn {
  right: 30px;
}

/* ==================== 图片缓存设置面板样式 ==================== */
.cache-settings-modal {
  /* 固定定位，覆盖整个视口 */
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  /* 在最顶层 */
  z-index: 999;
  /* 弹性布局 */
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 设置面板背景遮罩 */
.cache-settings-overlay {
  /* 绝对定位，覆盖整个modal */
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  /* 半透明黑色 */
  background: rgba(0, 0, 0, 0.5);
  /* 动画淡入 */
  animation: fadeIn 0.2s ease;
}

/* 淡入动画定义 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 设置面板容器 */
.cache-settings-panel {
  /* 相对定位 */
  position: relative;
  /* 在遮罩上方 */
  z-index: 1000;
  /* 最小宽度 */
  min-width: 400px;
  /* 深色背景 */
  background: #232323;
  /* 白色文字 */
  color: #fff;
  /* 圆角 */
  border-radius: 8px;
  /* 阴影 */
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
  /* 动画缩放进入 */
  animation: scaleIn 0.3s ease;
}

/* 缩放进入动画 */
@keyframes scaleIn {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

/* 面板头部 */
.cache-settings-header {
  /* 边框分隔 */
  border-bottom: 1px solid #3c3c3c;
  /* 内间距 */
  padding: 20px;
  /* 弹性布局 */
  display: flex;
  /* 两端对齐 */
  justify-content: space-between;
  /* 垂直居中 */
  align-items: center;
