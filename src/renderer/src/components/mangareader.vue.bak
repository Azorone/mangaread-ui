  padding: 3px 10px;
  /* 胶囊形圆角 */
  border-radius: 10px;
}

/* ==================== 灯箱控制按钮样式 ==================== */
/* 关闭按钮 + 导航按钮通用样式 */
.close-btn, .nav-btn {
  /* 绝对定位 */
  position: absolute;
  /* 透明白色背景 */
  background: rgba(255, 255, 255, 0.1);
  /* 白色图标 */
  color: white;
  /* 移除边框 */
  border: none;
  /* 小手光标 */
